# Copy to .env and fill in (never commit .env).

# Google AI Studio / Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: same key under alternate name
# GOOGLE_API_KEY=

# Optional model id (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ElevenLabs (https://elevenlabs.io — API key + voice ID from dashboard)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional TTS model (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Set to 0 to disable speaker playback (sentiment tab still updates)
# WEBHOOK_SPEAK_ENABLED=1

# Optional: Gemini timeout seconds (default 40)
# GEMINI_REQUEST_TIMEOUT=40
